# Required
ICEBREAKER_ANTHROPIC_API_KEY=sk-ant-...

# Google Search (pick one)
ICEBREAKER_SERPAPI_KEY=           # Get from https://serpapi.com
# OR
ICEBREAKER_SEARCHAPI_KEY=         # Get from https://www.searchapi.io
# OR
ICEBREAKER_GOOGLE_CSE_KEY=       # Google Custom Search API key
ICEBREAKER_GOOGLE_CSE_ID=        # Custom Search Engine ID

# Optional - Phase 2
ICEBREAKER_PROXYCURL_KEY=        # LinkedIn enrichment - https://proxycurl.com
ICEBREAKER_GITHUB_TOKEN=         # Higher rate limits for GitHub API
